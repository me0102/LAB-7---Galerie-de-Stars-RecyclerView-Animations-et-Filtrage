package com.example.celebrityhub.managers;

import com.example.celebrityhub.models.Celebrity;
import com.example.celebrityhub.interfaces.CrudOperation;
import com.example.celebrityhub.models.Celebrity;

import java.util.ArrayList;
import java.util.List;

public class CelebrityManager implements CrudOperation<Celebrity> {
    private List<Celebrity> celebritiesList;
    private static CelebrityManager uniqueInstance;

    private CelebrityManager() {
        celebritiesList = new ArrayList<>();
        populateData();
    }

    public static CelebrityManager getInstance() {
        if (uniqueInstance == null) {
            uniqueInstance = new CelebrityManager();
        }
        return uniqueInstance;
    }

    private void populateData() {
        celebritiesList.add(new Celebrity("Will Smith", "https://upload.wikimedia.org/wikipedia/commons/3/3f/TechCrunch_Disrupt_2019_%2848834434641%29_%28cropped%29.jpg", 4.6f));
        celebritiesList.add(new Celebrity("Natalie Portman", "https://upload.wikimedia.org/wikipedia/commons/d/d3/Natalie_Portman_%2848470988352%29_%28cropped%29.jpg", 4.9f));
        celebritiesList.add(new Celebrity("Morgan Freeman", "https://upload.wikimedia.org/wikipedia/commons/e/e4/Morgan_Freeman_Deauville_2018.jpg", 5.0f));
        celebritiesList.add(new Celebrity("Adele", "https://upload.wikimedia.org/wikipedia/commons/7/7c/Adele_2016.jpg", 4.8f));
        celebritiesList.add(new Celebrity("Leonardo DiCaprio", "https://upload.wikimedia.org/wikipedia/commons/4/46/Leonardo_Dicaprio_Cannes_2019.jpg", 4.8f));
        celebritiesList.add(new Celebrity("Scarlett Johansson", "https://upload.wikimedia.org/wikipedia/commons/2/2a/Scarlett_Johansson_by_Gage_Skidmore_2_%28cropped%29.jpg", 4.7f));
        celebritiesList.add(new Celebrity("Denzel Washington", "https://upload.wikimedia.org/wikipedia/commons/4/40/Denzel_Washington_2018.jpg", 4.9f));
        celebritiesList.add(new Celebrity("Zendaya", "https://upload.wikimedia.org/wikipedia/commons/2/28/Zendaya_-_2019_by_Glenn_Francis.jpg", 4.6f));
        celebritiesList.add(new Celebrity("Tom Hanks", "https://upload.wikimedia.org/wikipedia/commons/a/a9/Tom_Hanks_TIFF_2019.jpg", 5.0f));
        celebritiesList.add(new Celebrity("Rihanna", "https://upload.wikimedia.org/wikipedia/commons/c/c2/Rihanna_Fenty_2018.png", 4.7f));
        celebritiesList.add(new Celebrity("Tom Cruise", "https://upload.wikimedia.org/wikipedia/commons/3/33/Tom_Cruise_by_Gage_Skidmore_2.jpg", 4.5f));
        celebritiesList.add(new Celebrity("Angelina Jolie", "https://upload.wikimedia.org/wikipedia/commons/a/ad/Angelina_Jolie_2_June_2014_%28cropped%29.jpg", 4.8f));
        celebritiesList.add(new Celebrity("Brad Pitt", "https://upload.wikimedia.org/wikipedia/commons/4/4c/Brad_Pitt_2019_by_Glenn_Francis.jpg", 4.6f));
        celebritiesList.add(new Celebrity("Meryl Streep", "https://upload.wikimedia.org/wikipedia/commons/4/46/Meryl_Streep_December_2018.jpg", 5.0f));
        celebritiesList.add(new Celebrity("Dwayne Johnson", "https://upload.wikimedia.org/wikipedia/commons/f/f1/Dwayne_Johnson_2%2C_2013.jpg", 4.7f));
        celebritiesList.add(new Celebrity("Emma Watson", "https://upload.wikimedia.org/wikipedia/commons/7/7f/Emma_Watson_2013.jpg", 4.8f));
        celebritiesList.add(new Celebrity("Chris Hemsworth", "https://upload.wikimedia.org/wikipedia/commons/e/e8/Chris_Hemsworth_by_Gage_Skidmore_2_%28cropped%29.jpg", 4.5f));
        celebritiesList.add(new Celebrity("Keanu Reeves", "https://upload.wikimedia.org/wikipedia/commons/f/f2/Keanu_Reeves_2013_%2810615146086%29_%28cropped%29.jpg", 4.9f));
        celebritiesList.add(new Celebrity("Robert Downey Jr.", "https://upload.wikimedia.org/wikipedia/commons/9/94/Robert_Downey_Jr_2014_Comic_Con_%28cropped%29.jpg", 4.8f));
        celebritiesList.add(new Celebrity("Jennifer Lawrence", "https://upload.wikimedia.org/wikipedia/commons/0/0b/Jennifer_Lawrence_at_the_83rd_Academy_Awards_1.jpg", 4.6f));
        celebritiesList.add(new Celebrity("Ryan Gosling", "https://upload.wikimedia.org/wikipedia/commons/f/f6/Ryan_Gosling_in_2018.jpg", 4.7f));
        celebritiesList.add(new Celebrity("Margot Robbie", "https://upload.wikimedia.org/wikipedia/commons/0/0b/Margot_Robbie_at_Somerset_House_in_2013_%28cropped%29.jpg", 4.8f));
        celebritiesList.add(new Celebrity("Tom Holland", "https://upload.wikimedia.org/wikipedia/commons/3/3c/Tom_Holland_by_Gage_Skidmore.jpg", 4.7f));
        celebritiesList.add(new Celebrity("Jackie Chan", "https://upload.wikimedia.org/wikipedia/commons/8/8b/Jackie_Chan_July_2016.jpg", 4.9f));
        celebritiesList.add(new Celebrity("Samuel L. Jackson", "https://upload.wikimedia.org/wikipedia/commons/2/2a/Samuel_L._Jackson_2019_by_Glenn_Francis.jpg", 4.8f));
    }

    @Override
    public boolean insert(Celebrity item) {
        return celebritiesList.add(item);
    }

    @Override
    public boolean modify(Celebrity item) {
        for (Celebrity celeb : celebritiesList) {
            if (celeb.getIdentifier() == item.getIdentifier()) {
                celeb.setFullName(item.getFullName());
                celeb.setPhotoUrl(item.getPhotoUrl());
                celeb.setEvaluation(item.getEvaluation());
                return true;
            }
        }
        return false;
    }

    @Override
    public boolean remove(Celebrity item) {
        return celebritiesList.remove(item);
    }

    @Override
    public Celebrity getById(int id) {
        for (Celebrity celeb : celebritiesList) {
            if (celeb.getIdentifier() == id) {
                return celeb;
            }
        }
        return null;
    }

    @Override
    public List<Celebrity> getAll() {
        return celebritiesList;
    }
}
