<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"> <ImageView
    android:id="@+id/img_logo_splash"
    android:layout_width="140dp"
    android:layout_height="140dp"
    android:src="@drawable/ic_celeb"
    android:scaleX="0"
    android:scaleY="0"
    android:alpha="0"
    app:layout_constraintBottom_toTopOf="@+id/txt_splash_title"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/txt_splash_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="CELEBRITY HUB"
        android:textColor="#D4AF37" android:textSize="26sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/img_logo_splash" />

</androidx.constraintlayout.widget.ConstraintLayout>