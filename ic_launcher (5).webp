package com.example.celebrityhub.models;

public class Celebrity {
    private int identifier;
    private String fullName;
    private String photoUrl;
    private float evaluation;
    private static int globalCounter = 0;

    public Celebrity(String fullName, String photoUrl, float evaluation) {
        this.identifier = ++globalCounter;
        this.fullName = fullName;
        this.photoUrl = photoUrl;
        this.evaluation = evaluation;
    }

    public int getIdentifier() { return identifier; }
    public String getFullName() { return fullName; }
    public String getPhotoUrl() { return photoUrl; }
    public float getEvaluation() { return evaluation; }

    public void setFullName(String fullName) { this.fullName = fullName; }
    public void setPhotoUrl(String photoUrl) { this.photoUrl = photoUrl; }
    public void setEvaluation(float evaluation) { this.evaluation = evaluation; }
}
